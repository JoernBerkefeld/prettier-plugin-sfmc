{
    "name": "prettier-plugin-sfmc",
    "version": "1.0.0",
    "description": "Prettier plugin for Salesforce Marketing Cloud - AMPscript, Marketing Cloud Next Handlebars, SSJS, and SQL formatting",
    "type": "module",
    "main": "src/index.js",
    "exports": {
        ".": "./src/index.js"
    },
    "files": [
        "src",
        "docs",
        "README.md",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/JoernBerkefeld/prettier-plugin-sfmc.git"
    },
    "bugs": {
        "url": "https://github.com/JoernBerkefeld/prettier-plugin-sfmc/issues"
    },
    "homepage": "https://github.com/JoernBerkefeld/prettier-plugin-sfmc#readme",
    "author": "Joern Berkefeld",
    "scripts": {
        "example": "prettier --plugin . example.ampscript",
        "test": "node ./scripts/run-jest.mjs",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "prepare": "husky || true",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "keywords": [
        "prettier",
        "ampscript",
        "ssjs",
        "handlebars",
        "sql",
        "tsql",
        "transact-sql",
        "sfmc",
        "salesforce",
        "marketing-cloud",
        "plugin",
        "formatter"
    ],
    "license": "MIT",
    "dependencies": {
        "ampscript-data": "^2.0.3",
        "ampscript-parser": "^0.1.3",
        "handlebars-data": "^0.3.0",
        "prettier-plugin-sql": "^0.20.0",
        "ssjs-data": "^0.5.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@jest/globals": "^30.3.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.0.0",
        "eslint-plugin-prettier": "^5.5.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.1"
    },
    "peerDependencies": {
        "prettier": ">=3.7.0"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "lint-staged": {
        "*.{js,mjs,cjs}": [
            "eslint --fix"
        ]
    }
}
